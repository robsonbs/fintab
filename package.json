{
  "name": "software-developer",
  "version": "1.0.0",
  "description": "",
  "license": "MIT",
  "author": "Robson Barbosa Souza <powerrob92@gmail.com>",
  "main": "index.js",
  "scripts": {
    "commit": "cz",
    "dev": "npm run services:up && npm run services:wait:database && npm run migrations:up && (trap 'npm run postdev' INT TERM ; next dev)",
    "lint:check": "npm run lint:eslint:check && npm run lint:prettier:check",
    "lint:eslint:check": "eslint .",
    "lint:eslint:fix": "eslint --fix .",
    "lint:fix": "npm run lint:prettier:fix ;npm run lint:eslint:fix",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:secretlint:check": "npx secretlint --maskSecrets '**/*'",
    "migrations:create": "node-pg-migrate -m infra/migrations create",
    "migrations:up:dry": "node-pg-migrate -m infra/migrations --envPath .env.development --dry-run up",
    "migrations:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "postdev": "npm run services:down",
    "posttest": "npm run services:stop",
    "prepare": "husky",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:logs": "docker compose -f infra/compose.yaml logs -f",
    "services:restart": "npm run services:down && npm run services:up",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:wait:database": "node infra/scripts/wait-for-postgres.js",
    "test:sessions": "npm run services:up && concurrently --names next,jest --hide next --kill-others --success command-jest \"next dev\" \"jest --runInBand --verbose tests/integration/api/v1/sessions/post.test.js\"",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "test": "npm run services:up && concurrently --passthrough-arguments --names next,jest --hide next --kill-others --success command-jest \"next dev\" \"jest --runInBand --verbose\""
  },
  "engines": {
    "node": "24"
  },
  "dependencies": {
    "async-retry": "1.3.3",
    "bcryptjs": "3.0.3",
    "cookie": "1.1.1",
    "dotenv": "17.4.2",
    "dotenv-expand": "12.0.3",
    "next": "14.2.35",
    "next-connect": "1.0.0",
    "node-pg-migrate": "7.9.0",
    "nodemailer": "7.0.5",
    "pg": "8.20.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "swr": "2.4.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@faker-js/faker": "9.7.0",
    "@secretlint/secretlint-rule-no-dotenv": "11.5.0",
    "@secretlint/secretlint-rule-preset-recommend": "11.4.1",
    "@types/jest": "29.5.14",
    "commitizen": "4.3.1",
    "concurrently": "9.2.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "9.19.0",
    "eslint-config-next": "15.5.14",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "28.14.0",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "prettier": "3.8.3",
    "secretlint": "11.4.1",
    "set-cookie-parser": "2.7.1",
    "uuid": "11.1.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
