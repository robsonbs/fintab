{
  "name": "software-developer",
  "version": "1.0.0",
  "description": "",
  "license": "MIT",
  "author": "Robson Barbosa Souza <powerrob92@gmail.com>",
  "main": "index.js",
  "scripts": {
    "commit": "cz",
    "dev": "npm run services:up && npm run services:wait:database && npm run migrations:up && (trap 'npm run postdev' INT TERM ; next dev)",
    "lint:check": "npm run lint:eslint:check && npm run lint:prettier:check",
    "lint:eslint:check": "eslint .",
    "lint:eslint:fix": "eslint --fix .",
    "lint:fix": "npm run lint:eslint:fix && npm run lint:prettier:fix",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:secretlint:check": "npx secretlint --maskSecrets '**/*'",
    "migrations:create": "node-pg-migrate -m infra/migrations create",
    "migrations:up:dry": "node-pg-migrate -m infra/migrations --envPath .env.development --dry-run up",
    "migrations:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "postdev": "npm run services:down",
    "posttest": "npm run services:stop",
    "prepare": "husky",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:logs": "docker compose -f infra/compose.yaml logs -f",
    "services:restart": "npm run services:down && npm run services:up",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:wait:database": "node infra/scripts/wait-for-postgres.js",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "test": "npm run services:up && concurrently --names next,jest --hide next --kill-others --success command-jest \"next dev\" \"jest --runInBand --verbose\""
  },
  "engines": {
    "node": "24"
  },
  "dependencies": {
    "async-retry": "1.3.3",
    "dotenv": "16.4.4",
    "dotenv-expand": "11.0.6",
    "next": "13.1.6",
    "node-pg-migrate": "6.2.2",
    "pg": "8.11.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@secretlint/secretlint-rule-no-dotenv": "9.0.0",
    "@secretlint/secretlint-rule-preset-recommend": "9.0.0",
    "commitizen": "4.3.1",
    "concurrently": "9.1.2",
    "cz-conventional-changelog": "3.3.0",
    "eslint-config-next": "15.5.14",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "28.14.0",
    "eslint": "9.19.0",
    "globals": "15.15.0",
    "husky": "9.1.7",
    "jest": "29.6.2",
    "prettier": "3.8.1",
    "secretlint": "9.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
